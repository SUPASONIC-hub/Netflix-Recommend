<nav class="navbar navbar-expand-lg navbar-light bg-light mb-4 border-bottom">
  <div class="container-fluid">
    <a
      class="navbar-brand brand-art"
      href="/"
      <%= page === 'home' ? 'aria-current="page"' : '' %>
    >
      <img class="brand-mascot" src="/assets/brand.png" alt="브랜드 마스코트" />
      <img class="brand-netflix-logo" src="/assets/netflix-wordmark.svg" alt="Netflix" />
      <span class="brand-picks">PICKS</span>
    </a>
    <button
      type="button"
      class="btn btn-outline-secondary btn-sm comment-bubble-btn"
      data-bs-toggle="modal"
      data-bs-target="#commentSummaryModal"
      data-comment-summary-trigger
      aria-label="댓글 현황 열기"
      aria-controls="commentSummaryModal"
    >
      <span class="bubble-icon">&#128172;</span>
      <span
        class="comment-total-count"
        data-comment-total-count
        role="status"
        aria-live="polite"
        aria-atomic="true"
      ><%= totalCommentCount || 0 %></span>
    </button>
    <div class="d-flex header-actions">
      <% if (page === 'home') { %>
        <% if (isAdmin) { %>
        <a href="/admin/new" class="btn btn-primary btn-sm">추천 등록</a>
        <% } else { %>
        <a href="/admin/login" class="btn btn-primary btn-sm">관리자 로그인</a>
        <% } %>
      <% } else if (page === 'adminNew') { %>
      <a href="/admin/login" class="btn btn-primary btn-sm">관리자 로그인</a>
      <a href="/" class="btn btn-outline-secondary btn-sm">목록으로</a>
      <% } else if (page === 'adminEdit') { %>
      <a href="/admin/login" class="btn btn-primary btn-sm">관리자 로그인</a>
      <a href="/admin/new" class="btn btn-outline-secondary btn-sm">추천 등록</a>
      <a href="/content/<%= content.id %>" class="btn btn-outline-secondary btn-sm">상세로</a>
      <% } else { %>
      <a href="/admin/login" class="btn btn-primary btn-sm">관리자 로그인</a>
      <% } %>
    </div>
  </div>
</nav>
