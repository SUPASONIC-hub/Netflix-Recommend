<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/brand-32.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/assets/brand-48.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/brand-180.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="mask-icon" href="/assets/netflix-wordmark.svg" color="#e50914" />
    <meta name="theme-color" content="#101418" />
    <title><%= content.title %> - 異붿쿇 ?곸꽭</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Nanum+Gothic:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <style>
      body {
        font-family: 'Nanum Gothic', system-ui, -apple-system, BlinkMacSystemFont,
          'Segoe UI', sans-serif;
        font-size: 14px;
        background-color: #ffffff;
        color: #212529;
      }
.detail-body-text {
        font-size: 1.1rem;
        line-height: 1.7;
        white-space: pre-wrap;
        overflow-wrap: anywhere;
      }
      .info-box {
        border: 1px solid #9ec5fe;
        border-radius: 12px;
        padding: 16px;
        background: #e7f1ff;
      }
      .info-box h4 {
        font-size: 1rem;
        margin-bottom: 10px;
        font-weight: 700;
        color: #0b5ed7;
      }
      .info-box--rating {
        background: #d7ebff;
        border-color: #6ea8fe;
      }
      .info-box--note {
        background: #eaf4ff;
        border-color: #9ec5fe;
        padding: 18px;
      }
      .info-box--overview {
        background: #f0f7ff;
        border-color: #b6d4fe;
        padding: 20px;
      }
      .rating-box {
        padding: 16px 18px;
        background: #cfe2ff;
        border-color: #4c8ef7;
        box-shadow: 0 8px 18px rgba(11, 94, 215, 0.15);
      }
      .rating-score {
        display: flex;
        align-items: baseline;
        gap: 8px;
        font-weight: 700;
        color: #0b5ed7;
      }
      .rating-number {
        font-size: 2.4rem;
        line-height: 1;
      }
      .rating-max {
        font-size: 1.3rem;
        opacity: 0.85;
      }
      .rating-stars {
        margin-top: 8px;
        font-size: 1.7rem;
        letter-spacing: 2px;
      }
      .star {
        position: relative;
        display: inline-block;
        color: #cfe2ff;
        line-height: 1;
      }
      .star::after {
        content: '\2605';
        position: absolute;
        left: 0;
        top: 0;
        width: var(--fill, 0%);
        overflow: hidden;
        color: #0b5ed7;
        white-space: nowrap;
      }
      @media (max-width: 575.98px) {
        body {
          font-size: 13px;
        }
        .navbar .container-fluid {
          flex-direction: column;
          align-items: stretch;
          gap: 10px;
        }
        .detail-body-text {
          font-size: 1rem;
        }
        .rating-number {
          font-size: 2rem;
        }
        .rating-stars {
          font-size: 1.4rem;
        }
        .info-box--note,
        .info-box--overview {
          padding: 16px;
        }
      }
    </style>
      <link href="/styles/common.css" rel="stylesheet" />
</head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4 border-bottom">
      <div class="container-fluid">
        <a class="navbar-brand brand-art" href="/">
          <img class="brand-mascot" src="/assets/brand.png" alt="Brand mascot" />
          <img class="brand-netflix-logo" src="/assets/netflix-wordmark.svg" alt="Netflix" />
          <span class="brand-picks">PICKS</span>
        </a>
        <button
          type="button"
          class="btn btn-outline-secondary btn-sm comment-bubble-btn"
          data-bs-toggle="modal"
          data-bs-target="#commentSummaryModal"
          aria-label="댓글 현황 열기" data-comment-summary-trigger
        >
          <span class="bubble-icon">&#128172;</span>
          <span class="comment-total-count" data-comment-total-count role="status" aria-live="polite" aria-atomic="true"><%= totalCommentCount || 0 %></span>
        </button>

      </div>
    </nav>

    <div class="container">
      <div class="row mb-4">
        <% const backdropSrc = content.backdropPath ? 'https://image.tmdb.org/t/p/w780' + content.backdropPath : (content.posterPath ? 'https://image.tmdb.org/t/p/w780' + content.posterPath : (content.posterUrl || '')); %>
        <% if (backdropSrc) { %>
        <div class="col-12 mb-3">
          <div class="rounded" style="background-image: url('<%= backdropSrc %>'); background-size: cover; background-position: center; padding: 20px; min-height: 220px;">
            <div class="bg-dark bg-opacity-50 text-white p-3 rounded">
              <h2 class="mb-0"><%= content.title || content.name || '' %></h2>
            </div>
          </div>
        </div>
        <% } %>
        <div class="col-md-4">
          <% const posterSrc = content.posterUrl || (content.posterPath ? 'https://image.tmdb.org/t/p/w500' + content.posterPath : ''); %>
          <% if (posterSrc) { %>
          <img
            src="<%= posterSrc %>"
            class="img-fluid rounded"
            alt="<%= content.title || content.name || '' %>"
          />
          <% } %>
        </div>
        <div class="col-md-8">
          <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
            <h1 class="mb-0"><%= content.title || content.name || '' %></h1>
            <% if (isAdmin) { %>
            <a href="/admin/content/<%= content.id %>/edit" class="btn btn-sm btn-outline-secondary">?섏젙</a>
            <form
              method="post"
              action="/admin/content/<%= content.id %>/delete"
              onsubmit="return confirm('??異붿쿇????젣?좉퉴??');"
              class="d-inline"
            >
              <button type="submit" class="btn btn-sm btn-outline-danger">??젣</button>
            </form>
            <% } %>
          </div>
          <p class="text-muted">
            <%= content.year || content.pubDate || '' %> 쨌 <%= content.type || '肄섑뀗痢? %>
          </p>
          <% const ratingValue = typeof content.myRating === 'number' ? content.myRating : (parseFloat(content.myRating) || 0); %>
          <div class="info-box info-box--rating rating-box mb-3">
            <h4>SUPASONIC???됱젏</h4>
            <div class="rating-score">
              <span class="rating-number"><%= ratingValue %></span>
              <span class="rating-max">/ 5</span>
            </div>
            <div class="rating-stars" aria-label="SUPASONIC???됱젏 <%= ratingValue %>??>
              <% for (let i = 1; i <= 5; i++) { %>
              <% const fill = Math.max(0, Math.min(1, ratingValue - (i - 1))) * 100; %>
              <span class="star" style="--fill: <%= fill %>%">&#9733;</span>
              <% } %>
            </div>
          </div>
          <div class="info-box info-box--note mb-4">
            <h4>?섏쓽 媛먯긽</h4>
            <p class="detail-body-text mb-0"><%= content.myNote %></p>
          </div>
          <% if (content.overview) { %>
          <div class="info-box info-box--overview mb-3">
            <h4>?곹솕 ?댁슜</h4>
            <p class="detail-body-text mb-0"><%= content.overview %></p>
          </div>
          <% } %>
<ul class="list-unstyled">
            <% if (content.releaseDate || content.firstAirDate) { %>
            <li>
              <strong>怨듦컻?쇱떆:</strong>
              <%= content.releaseDate || content.firstAirDate %>
            </li>
            <% } %>
            <% if (typeof content.popularity === 'number') { %>
            <li><strong>?멸린吏??</strong> <%= content.popularity %></li>
            <% } %>
            <% if (typeof content.voteAverage === 'number') { %>
            <li><strong>TMDB ?됱젏:</strong> <%= content.voteAverage %></li>
            <% } %>
            <% if (typeof content.voteCount === 'number') { %>
            <li><strong>TMDB ?ы몴 ??</strong> <%= content.voteCount %></li>
            <% } %>
            <% if (typeof content.adult === 'boolean') { %>
            <li><strong>?깆씤臾??щ?:</strong> <%= content.adult ? '?? : '?꾨땲?? %></li>
            <% } %>
            <% if (content.mediaType) { %>
            <li><strong>硫?곌??됯껐怨????</strong> <%= content.mediaType %></li>
            <% } %>
            <% if (Array.isArray(content.genreNames) && content.genreNames.length) { %>
            <li><strong>?λⅤ:</strong> <%= content.genreNames.join(', ') %></li>
            <% } else if (Array.isArray(content.genreIds) && content.genreIds.length) { %>
            <li><strong>?λⅤ:</strong> <%= content.genreIds.join(', ') %></li>
            <% } %>
          </ul>
          <% if (content.tags && content.tags.length) { %>
          <p>
            ?쒓렇:
            <% content.tags.forEach(function (t) { %>
            <span class="badge bg-info text-dark"><%= t %></span>
            <% }); %>
          </p>
          <% } %>
        </div>
      </div>

      <hr class="border-secondary" />

      <div class="mb-4">
        <h3>?볤?</h3>
        <% if (!comments || comments.length === 0) { %>
        <p>?꾩쭅 ?볤????놁뒿?덈떎. 泥??볤????④꺼蹂댁꽭??</p>
        <% } else { %>
        <ul class="list-group">
          <% comments.forEach(function (cm) { %>
          <li class="list-group-item">
            <strong><%= cm.nickname %></strong>
            <small class="text-light-50">
              (<%= new Date(cm.createdAt).toLocaleString('ko-KR') %>)
            </small>
            <p class="mb-0"><%= cm.text %></p>
          </li>
          <% }); %>
        </ul>
        <% } %>
      </div>

      <div class="mb-5">
        <h4>?볤? ?④린湲?(濡쒓렇??遺덊븘??</h4>
        <form method="post" action="/content/<%= content.id %>/comments">
          <div class="mb-3">
            <label class="form-label">?됰꽕??</label>
            <input type="text" name="nickname" class="form-control" required />
          </div>
          <div class="mb-3">
            <label class="form-label">?댁슜</label>
            <textarea name="text" class="form-control" rows="3" required></textarea>
          </div>
          <button type="submit" class="btn btn-primary">?볤? ?깅줉</button>
        </form>
      </div>
    </div>
      <%- include('partials/commentSummaryModal') %>
      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>













