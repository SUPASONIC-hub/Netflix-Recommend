<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/brand-32.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/assets/brand-48.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/brand-180.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="mask-icon" href="/assets/netflix-wordmark.svg" color="#e50914" />
    <meta name="theme-color" content="#101418" />
    <title>異붿쿇 ?깅줉</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Nanum+Gothic:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <style>
      body {
        font-family: 'Nanum Gothic', system-ui, -apple-system, BlinkMacSystemFont,
          'Segoe UI', sans-serif;
        font-size: 14px;
        background-color: #ffffff;
        color: #212529;
      }
@media (max-width: 575.98px) {
        body {
          font-size: 13px;
        }
        .navbar .container-fluid {
          flex-direction: column;
          align-items: stretch;
          gap: 10px;
        }
        .navbar .btn {
          width: 100%;
        }
        .modal-dialog {
          margin: 1rem;
        }
        .table-responsive .btn,
        .table-responsive form {
          width: 100%;
        }
        .table-responsive .d-flex {
          flex-direction: column;
        }
      }
    </style>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"
      defer
    ></script>
    <script>
      async function searchTmdb() {
        const q = document.getElementById('searchQuery').value.trim();
        const listEl = document.getElementById('searchResults');
        listEl.innerHTML = '';
        if (!q) return;

        try {
          const res = await fetch('/api/tmdb/search?q=' + encodeURIComponent(q));
          const data = await res.json();

          if (data && data.error) {
            alert('寃??以??ㅻ쪟: ' + data.error);
            return;
          }

          if (!Array.isArray(data) || data.length === 0) {
            listEl.innerHTML = '<p>寃??寃곌낵媛 ?놁뒿?덈떎.</p>';
            return;
          }

          data.forEach((item) => {
            const div = document.createElement('div');
            div.className = 'card mb-2';
            div.innerHTML = `
              <div class="card-body d-flex">
                ${
                  item.posterUrl
                    ? `<img src="${item.posterUrl}" style="height:80px" class="me-3" />`
                    : ''
                }
                <div class="flex-grow-1">
                  <h5 class="card-title">${item.title}</h5>
                  <p class="card-text">${item.pubDate || ''}</p>
                  <button type="button" class="btn btn-sm btn-primary">?좏깮?섍린</button>
                </div>
              </div>
            `;
            div.querySelector('button').addEventListener('click', () => {
              document.getElementById('tmdbId').value = item.tmdbId;
              document.getElementById('title').value = item.title || item.name || '';
              document.getElementById('name').value = item.name || '';
              document.getElementById('overview').value = item.overview || '';
              document.getElementById('releaseDate').value = item.releaseDate || '';
              document.getElementById('firstAirDate').value = item.firstAirDate || '';
              document.getElementById('posterPath').value = item.posterPath || '';
              document.getElementById('posterUrl').value = item.posterUrl || '';
              document.getElementById('backdropPath').value = item.backdropPath || '';
              document.getElementById('genreIds').value = JSON.stringify(
                Array.isArray(item.genreIds) ? item.genreIds : []
              );
              document.getElementById('popularity').value =
                item.popularity !== null && item.popularity !== undefined
                  ? String(item.popularity)
                  : '';
              document.getElementById('voteAverage').value =
                item.voteAverage !== null && item.voteAverage !== undefined
                  ? String(item.voteAverage)
                  : '';
              document.getElementById('voteCount').value =
                item.voteCount !== null && item.voteCount !== undefined
                  ? String(item.voteCount)
                  : '';
              document.getElementById('adult').value = item.adult ? 'true' : 'false';
              document.getElementById('mediaType').value = item.mediaType || '';
              document.getElementById('year').value = item.pubDate || '';
              document.getElementById('type').value = item.mediaType || 'movie';

              // 紐⑤떖 ?リ린
              const modalEl = document.getElementById('searchModal');
              const modal = bootstrap.Modal.getInstance(modalEl);
              if (modal) {
                modal.hide();
              }
            });
            listEl.appendChild(div);
          });

          // 寃??寃곌낵媛 ?덉쑝硫?紐⑤떖 蹂댁뿬二쇨린
          const modalEl = document.getElementById('searchModal');
          const modal = new bootstrap.Modal(modalEl);
          modal.show();
        } catch (e) {
          console.error(e);
          alert('TMDB 寃???붿껌 以??ㅻ쪟媛 諛쒖깮?덉뒿?덈떎. 肄섏넄???뺤씤??二쇱꽭??');
        }
      }

      window.addEventListener('DOMContentLoaded', () => {
        const input = document.getElementById('searchQuery');
        if (input) {
          input.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
              e.preventDefault();
              searchTmdb();
            }
          });
        }
      });
    </script>
      <link href="/styles/common.css" rel="stylesheet" />
</head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4 border-bottom">
      <div class="container-fluid">
        <a class="navbar-brand brand-art" href="/">
          <img class="brand-mascot" src="/assets/brand.png" alt="Brand mascot" />
          <img class="brand-netflix-logo" src="/assets/netflix-wordmark.svg" alt="Netflix" />
          <span class="brand-picks">PICKS</span>
        </a>
        <button
          type="button"
          class="btn btn-outline-secondary btn-sm comment-bubble-btn"
          data-bs-toggle="modal"
          data-bs-target="#commentSummaryModal"
          aria-label="댓글 현황 열기" data-comment-summary-trigger
        >
          <span class="bubble-icon">&#128172;</span>
          <span class="comment-total-count" data-comment-total-count role="status" aria-live="polite" aria-atomic="true"><%= totalCommentCount || 0 %></span>
        </button>

        <div class="d-flex gap-2">
          <a href="/admin/login" class="btn btn-primary btn-sm">관리자 로그인</a>
          <a href="/" class="btn btn-outline-light btn-sm">紐⑸줉?쇰줈</a>
        </div>
      </div>
    </nav>

    <div class="container mb-5">
      <h1 class="mb-3">異붿쿇 ?깅줉</h1>

      <div class="mb-4">
        <label class="form-label">TMDB 肄섑뀗痢?寃??</label>
        <div class="input-group mb-2">
          <input
            type="text"
            id="searchQuery"
            class="form-control"
            placeholder="작품 제목을 입력하세요"
          />
          <button type="button" class="btn btn-primary" onclick="searchTmdb()">
            寃??
          </button>
        </div>
      </div>

      <div
        class="modal fade"
        id="searchModal"
        tabindex="-1"
        aria-labelledby="searchModalLabel"
        aria-hidden="true"
      >
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title" id="searchModalLabel">TMDB 寃??寃곌낵</h5>
              <button
                type="button"
                class="btn-close btn-close-white"
                data-bs-dismiss="modal"
                aria-label="닫기"
              ></button>
            </div>
            <div class="modal-body">
              <div id="searchResults"></div>
            </div>
          </div>
        </div>
      </div>

      <hr class="border-secondary" />

      <form method="post" action="/admin/content">
        <h3 class="mb-3">?좏깮???묓뭹 + ?섎쭔??媛먯긽</h3>
        <input type="hidden" id="tmdbId" name="tmdbId" />
        <input type="hidden" id="name" name="name" />
        <input type="hidden" id="overview" name="overview" />
        <input type="hidden" id="releaseDate" name="releaseDate" />
        <input type="hidden" id="firstAirDate" name="firstAirDate" />
        <input type="hidden" id="posterPath" name="posterPath" />
        <input type="hidden" id="backdropPath" name="backdropPath" />
        <input type="hidden" id="genreIds" name="genreIds" />
        <input type="hidden" id="popularity" name="popularity" />
        <input type="hidden" id="voteAverage" name="voteAverage" />
        <input type="hidden" id="voteCount" name="voteCount" />
        <input type="hidden" id="adult" name="adult" />
        <input type="hidden" id="mediaType" name="mediaType" />
        <div class="mb-3">
          <label class="form-label">?쒕ぉ</label>
          <input type="text" id="title" name="title" class="form-control" readonly />
        </div>
        <div class="mb-3">
          <label class="form-label">?ъ뒪??URL</label>
          <input type="text" id="posterUrl" name="posterUrl" class="form-control" />
        </div>
        <div class="mb-3">
          <label class="form-label">?곕룄</label>
          <input type="text" id="year" name="year" class="form-control" />
        </div>
        <div class="mb-3">
          <label class="form-label">???</label>
          <input type="text" id="type" name="type" class="form-control" value="movie" />
        </div>
        <div class="mb-3">
          <label class="form-label">?섏쓽 媛먯긽</label>
          <textarea name="myNote" class="form-control" rows="4" required></textarea>
        </div>
        <div class="mb-3">
          <label class="form-label">蹂꾩젏 (0.5 ~ 5)</label>
          <input
            type="number"
            step="0.5"
            min="0.5"
            max="5"
            name="myRating"
            class="form-control"
            required
          />
        </div>
        <div class="mb-3">
          <label class="form-label">?쒓렇 (?쇳몴濡?援щ텇)</label>
          <input
            type="text"
            name="tags"
            class="form-control"
            placeholder="?? ?ㅻ┫?? 媛議? 二쇰쭚??蹂닿린 醫뗭쓬"
          />
        </div>
        <button type="submit" class="btn btn-primary">?깅줉?섍린</button>
      </form>

      <hr class="border-secondary my-5" />

      <section>
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h3 class="mb-0">湲곗〈 異붿쿇 紐⑸줉 愿由?</h3>
          <span class="badge bg-secondary">珥?<%= Array.isArray(contents) ? contents.length : 0 %>媛?/span>
        </div>
        <form method="get" action="/admin/new" class="row g-2 align-items-center mb-3">
          <div class="col-12 col-md-6">
            <input
              type="text"
              name="manageQ"
              class="form-control"
              placeholder="?쒕ぉ 寃??.."
              value="<%= manageQuery || '' %>"
            />
          </div>
          <div class="col-12 col-md-3">
            <select name="manageSort" class="form-select">
              <option value="latest" <%= manageSort === 'latest' ? 'selected' : '' %>>理쒖떊??</option>
              <option value="rating" <%= manageSort === 'rating' ? 'selected' : '' %>>?됱젏??</option>
            </select>
          </div>
          <div class="col-12 col-md-auto">
            <button type="submit" class="btn btn-primary">?곸슜</button>
            <a href="/admin/new" class="btn btn-outline-secondary ms-2">珥덇린??</a>
          </div>
        </form>

        <% if (!contents || contents.length === 0) { %>
        <p class="text-muted">?깅줉??異붿쿇???놁뒿?덈떎.</p>
        <% } else { %>
        <div class="table-responsive">
          <table class="table table-striped table-bordered align-middle">
            <thead class="table-light">
              <tr>
                <th style="width: 70px;">?ъ뒪??/th>
                <th>?쒕ぉ</th>
                <th style="width: 110px;">???/th>
                <th style="width: 90px;">?됱젏</th>
                <th style="width: 220px;">愿由?/th>
              </tr>
            </thead>
            <tbody>
              <% contents.forEach(function (c) { %>
              <tr>
                <td class="text-center">
                  <% const poster = c.posterUrl || (c.posterPath ? 'https://image.tmdb.org/t/p/w92' + c.posterPath : ''); %>
                  <% if (poster) { %>
                  <img
                    src="<%= poster %>"
                    alt="<%= c.title || c.name || '' %>"
                    style="width: 52px; height: 78px; object-fit: cover; border-radius: 4px;"
                  />
                  <% } else { %>
                  <span class="text-muted small">?놁쓬</span>
                  <% } %>
                </td>
                <td>
                  <div class="fw-bold"><%= c.title || c.name || '' %></div>
                  <div class="text-muted small"><%= c.year || '' %></div>
                </td>
                <td><%= c.type || c.mediaType || '-' %></td>
                <td><%= typeof c.myRating === 'number' ? c.myRating : '-' %></td>
                <td>
                  <div class="d-flex gap-2">
                    <a href="/content/<%= c.id %>" class="btn btn-sm btn-outline-primary">?곸꽭</a>
                    <a href="/admin/content/<%= c.id %>/edit" class="btn btn-sm btn-outline-secondary">?섏젙</a>
                    <form
                      method="post"
                      action="/admin/content/<%= c.id %>/delete"
                      onsubmit="return confirm('??異붿쿇????젣?좉퉴??');"
                      class="d-inline"
                    >
                      <button type="submit" class="btn btn-sm btn-outline-danger">??젣</button>
                    </form>
                  </div>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <% } %>
      </section>
    </div>
      <%- include('partials/commentSummaryModal') %>
  </body>
</html>













