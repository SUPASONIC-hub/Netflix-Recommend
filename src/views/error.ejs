<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/brand-32.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/assets/brand-48.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/brand-180.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <title><%= statusCode %> - <%= title %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link href="/styles/common.css" rel="stylesheet" />
  </head>
  <body>
    <%- include('partials/siteHeader', { page: 'error', isAdmin: isAdmin }) %>
    <div class="container py-5">
      <div class="p-4 border rounded bg-light">
        <h1 class="h4 mb-2"><%= title %></h1>
        <p class="mb-3"><%= message %></p>
        <p class="text-muted mb-4">요청 ID: <code><%= requestId %></code></p>
        <div class="d-flex gap-2">
          <a href="/" class="btn btn-primary btn-sm">홈으로 이동</a>
          <button type="button" class="btn btn-outline-secondary btn-sm" onclick="history.back()">
            이전 페이지
          </button>
        </div>
      </div>
    </div>
    <%- include('partials/commentSummaryModal') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
